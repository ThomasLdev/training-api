meta {
  name: 4 - ETag validation
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/courses
  body: none
  auth: none
}

headers {
  Accept: application/ld+json
  If-None-Match: {{etag}}
}

docs {
  Exercise 4 test — ETag validation:
  1. Do a GET /courses without If-None-Match, note the ETag header value
  2. Copy that value into the "etag" environment variable
  3. Run this request with If-None-Match
  4. Observe: 304 Not Modified or 200?
}
