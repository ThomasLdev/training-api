meta {
  name: 1 - Cache MISS then HIT
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/courses
  body: none
  auth: none
}

headers {
  Accept: application/ld+json
}

docs {
  Run this request 2 times in a row.

  1st time: X-Cache: MISS (Varnish asks PHP)
  2nd time: X-Cache: HIT + Age > 0 (Varnish serves directly)
}
