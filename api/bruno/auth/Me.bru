meta {
  name: Me
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/me
  body: none
  auth: none
}

headers {
  Accept: application/ld+json
}

docs {
  Returns the authenticated user's profile.
  The JWT is automatically injected by the collection script.

  - Admin: uuid, email, roles
  - Student: + embedded student object
  - Instructor: + embedded instructor object
}
