meta {
  name: Login as instructor
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/auth/token
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Accept: application/json
}

body:json {
  {
    "email": "instructor@training.local",
    "password": "password"
  }
}

script:post-response {
  const token = res.body?.token;
  if (token) {
    bru.setVar('jwt', token);
  }
}
