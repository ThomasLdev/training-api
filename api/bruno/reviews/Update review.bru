meta {
  name: Update review
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/courses/{{courseUuid}}/reviews/{{reviewUuid}}
  body: json
  auth: none
}

headers {
  Content-Type: application/merge-patch+json
  Accept: application/ld+json
}

body:json {
  {
    "rating": 4,
    "comment": "Commentaire modifié via Bruno"
  }
}
