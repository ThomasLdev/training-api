meta {
  name: Get course
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/courses/{{courseUuid}}
  body: none
  auth: none
}

headers {
  Accept: application/ld+json
}

docs {
  Course detail with embedded modules.

  Expected cache headers:
  - Cache-Control: max-age=60, public, s-maxage=3600
  - X-Cache: HIT/MISS (Varnish)
}
